{
  "name": "api-workbench",
  "version": "1.0.0-beta.16",
  "description": "A local-first, open-source Postman alternative for API testing and development.",
  "author": {
    "name": "Matthias Kopeinigg",
    "email": "matthiaskopeinigg@gmail.com",
    "url": "https://github.com/matthiaskopeinigg"
  },
  "homepage": "https://matthiaskopeinigg.github.io/api-workbench/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matthiaskopeinigg/api-workbench.git"
  },
  "bugs": {
    "url": "https://github.com/matthiaskopeinigg/api-workbench/issues"
  },
  "license": "MIT",
  "keywords": [
    "api-client",
    "postman-alternative",
    "http-client",
    "rest-client",
    "local-first",
    "electron",
    "angular",
    "developer-tools"
  ],
  "main": "electron/main.js",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng build --configuration production && electron .",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "tsc --noEmit -p tsconfig.app.json",
    "electron:dev": "electron electron/main.js",
    "dev": "concurrently -k \"ng serve --host 127.0.0.1 --port 4200\" \"wait-on -t 120000 http://127.0.0.1:4200/ && electron .\"",
    "pack": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ng build --configuration production && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder build --dir",
    "electron:build": "ng build --configuration production && electron-builder build --win --linux --mac",
    "electron:build:win": "ng build --configuration production && electron-builder build --win",
    "icons": "node scripts/generate-icons.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.api.workbench",
    "productName": "API Workbench",
    "copyright": "Copyright © 2026",
    "icon": "public/icon.ico",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "files": [
      "dist/api-workbench/browser/**/*",
      "dist/api-workbench/prerendered-routes.json",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "API Workbench",
      "artifactName": "${productName}Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/logo.png",
      "category": "Development"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "matthiaskopeinigg",
        "repo": "api-workbench"
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.9.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "js-yaml": "^4.1.1",
    "rxjs": "~7.8.0",
    "socks-proxy-agent": "^10.0.0",
    "tough-cookie": "^6.0.0",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.10.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^39.0.0",
    "electron-builder": "^26.4.0",
    "jasmine-core": "~5.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "png2icons": "^2.0.1",
    "typescript": "~5.7.2",
    "wait-on": "^9.0.3"
  }
}
