{
  "items": [
    {
      "id": "a1000000-0000-4000-8000-000000000021",
      "title": "Sample: public API smoke",
      "updatedAt": 1700000000000,
      "description": "Hits JSONPlaceholder and httpbin; expects 2xx.",
      "variables": [],
      "cases": [
        {
          "id": "c1000000-0000-4000-8000-000000000001",
          "name": "Post 1",
          "enabled": true,
          "target": { "kind": "saved", "requestId": "a1000000-0000-4000-8000-000000000010" },
          "assertions": [
            { "kind": "status", "expected": 200 },
            { "kind": "body", "path": "$.id", "op": "jsonpath-truthy" }
          ],
          "extracts": []
        },
        {
          "id": "c1000000-0000-4000-8000-000000000002",
          "name": "httpbin GET",
          "enabled": true,
          "target": { "kind": "saved", "requestId": "a1000000-0000-4000-8000-000000000011" },
          "assertions": [
            { "kind": "status", "expected": 200 },
            { "kind": "body", "path": "$.url", "op": "jsonpath-truthy" }
          ],
          "extracts": []
        }
      ]
    },
    {
      "id": "a1000000-0000-4000-8000-000000000030",
      "title": "Complex: extractions, chained URL, assertions",
      "updatedAt": 1700000001000,
      "description": "Suite-scoped var 'note'; extract userId from Reqres; next case uses {{userId}} in URL. Mix of status ranges, latency, headers, body jsonpath, POST, snapshot.",
      "variables": [{ "key": "note", "value": "config-seed" }],
      "regressionMode": false,
      "cases": [
        {
          "id": "c1000000-0000-4000-8000-000000000201",
          "name": "Reqres user + extract id",
          "enabled": true,
          "target": { "kind": "saved", "requestId": "a1000000-0000-4000-8000-000000000012" },
          "assertions": [
            { "kind": "status", "expected": "2xx" },
            { "kind": "latency", "failAboveMs": 30000, "warnAboveMs": 800 },
            { "kind": "header", "name": "content-type", "op": "contains", "value": "json" },
            { "kind": "body", "path": "$.data.email", "op": "jsonpath-equals", "value": "george.bluth@reqres.in" },
            { "kind": "body", "path": "$.data", "op": "jsonpath-truthy" }
          ],
          "extracts": [{ "as": "userId", "source": "$.data.id" }]
        },
        {
          "id": "c1000000-0000-4000-8000-000000000202",
          "name": "Chained: JSONPlaceholder /users/{userId}",
          "enabled": true,
          "target": {
            "kind": "inline",
            "method": "GET",
            "url": "{{jsonPlaceholderBase}}/users/{{userId}}",
            "headers": [{ "key": "Accept", "value": "application/json" }],
            "body": ""
          },
          "assertions": [
            { "kind": "status", "expected": 200 },
            { "kind": "body", "path": "$.id", "op": "jsonpath-equals", "value": "1" },
            { "kind": "body", "path": "$.name", "op": "jsonpath-truthy" }
          ],
          "extracts": []
        },
        {
          "id": "c1000000-0000-4000-8000-000000000203",
          "name": "Create post (saved POST)",
          "enabled": true,
          "target": { "kind": "saved", "requestId": "a1000000-0000-4000-8000-000000000015" },
          "assertions": [
            { "kind": "status", "expected": 201 },
            { "kind": "body", "path": "$.id", "op": "jsonpath-truthy" },
            { "kind": "body", "path": "$.title", "op": "jsonpath-equals", "value": "config seed" }
          ],
          "extracts": [{ "as": "createdPostId", "source": "$.id" }]
        },
        {
          "id": "c1000000-0000-4000-8000-000000000204",
          "name": "httpbin + latency",
          "enabled": true,
          "target": { "kind": "saved", "requestId": "a1000000-0000-4000-8000-000000000011" },
          "assertions": [
            { "kind": "status", "expected": 200 },
            { "kind": "latency", "failAboveMs": 20000, "warnAboveMs": 1500 },
            { "kind": "body", "path": "$", "op": "jsonpath-truthy" }
          ],
          "extracts": []
        },
        {
          "id": "c1000000-0000-4000-8000-000000000205",
          "name": "Snapshot baseline (GET post 1)",
          "enabled": true,
          "target": { "kind": "saved", "requestId": "a1000000-0000-4000-8000-000000000010" },
          "assertions": [
            { "kind": "status", "expected": 200 },
            {
              "kind": "snapshot",
              "id": "a1000000-0000-4000-8000-0000000000c1",
              "matchStatus": true,
              "includeHeaders": ["content-type"]
            }
          ],
          "extracts": []
        }
      ]
    }
  ]
}
